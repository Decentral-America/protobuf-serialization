{
  "name": "@decentralchain/protobuf-serialization",
  "version": "2.0.0",
  "description": "Official Protocol Buffers schema definitions and multi-language bindings for the DecentralChain blockchain protocol — encoding/decoding transactions, blocks, events, and gRPC APIs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./proto/*": "./proto/*"
  },
  "files": [
    "dist",
    "proto",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.6.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/protobuf-serialization.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/protobuf-serialization#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/protobuf-serialization/issues"
  },
  "scripts": {
    "generate": "pbjs -t static-module --force-long --no-create --no-verify --no-convert --no-delimited --no-beautify -w es6 --root decentralchain --path proto -o dist/index.js \"proto/waves/**/*.proto\"",
    "generate:types": "pbts -o dist/index.d.ts --no-comments dist/index.js",
    "build": "rm -rf dist && mkdir dist && npm run generate && npm run generate:types && npm run generate -- --no-comments",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:publint": "publint",
    "check:exports": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "check:size": "size-limit",
    "validate": "npm audit --audit-level=moderate && npm run format:check && npm run lint && npm run build && npm run typecheck && npm run test && npm run check:publint && npm run check:exports && npm run check:size",
    "bulletproof": "npm run format && npm run lint:fix && npm run build && npm run typecheck && npm run test",
    "bulletproof:check": "npm run format:check && npm run lint && npm run build && npm run typecheck && npm run test",
    "prepublishOnly": "npm run validate",
    "prepack": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "500 kB"
    }
  ],
  "keywords": [
    "decentralchain",
    "dcc",
    "protobuf",
    "serialization",
    "blockchain",
    "grpc",
    "protocol-buffers",
    "proto",
    "schema",
    "transactions",
    "dapp",
    "smart-contracts",
    "web3",
    "decentralized",
    "binary-encoding"
  ],
  "author": "DecentralChain",
  "license": "MIT",
  "dependencies": {
    "long": "^5.3.2",
    "protobufjs": "^8.0.0"
  },
  "overrides": {
    "protobufjs-cli": {
      "protobufjs": "$protobufjs"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@eslint/js": "10.0.1",
    "@size-limit/preset-small-lib": "12.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "3.8.1",
    "protobufjs-cli": "2.0.0",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
