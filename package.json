{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/protobuf-serialization/issues"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0"
  },
  "description": "Official Protocol Buffers schema definitions and multi-language bindings for the DecentralChain blockchain protocol — encoding/decoding transactions, blocks, events, and gRPC APIs.",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.10",
    "@bufbuild/buf": "1.67.0",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@evilmartians/lefthook": "2.1.4",
    "@size-limit/preset-small-lib": "12.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "publint": "0.3.18",
    "size-limit": "12.0.1",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./proto/*": "./proto/*"
  },
  "files": [
    "dist",
    "proto",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/protobuf-serialization#readme",
  "keywords": [
    "decentralchain",
    "dcc",
    "protobuf",
    "serialization",
    "blockchain",
    "grpc",
    "protocol-buffers",
    "proto",
    "schema",
    "transactions",
    "dapp",
    "smart-contracts",
    "web3",
    "decentralized",
    "binary-encoding"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "name": "@decentralchain/protobuf-serialization",
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/protobuf-serialization.git"
  },
  "scripts": {
    "build": "rm -rf dist && buf generate && tsdown",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "generate": "buf generate",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "npm run build",
    "prepare": "lefthook install",
    "prepublishOnly": "npm run validate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run build && npm run typecheck && npm run test && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "sideEffects": false,
  "size-limit": [
    {
      "limit": "500 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "3.0.0"
}
